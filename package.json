{
  "name": "coffee-timer",
  "version": "1.0.0",
  "description": "Simple, relaxing coffee timer application with web push notifications",
  "packageManager": "pnpm@10.20.0+sha512.cf9998222162dd85864d0a8102e7892e7ba4ceadebbf5a31f9c2fce48dfce317a9c53b9f6464d1ef9042cba2e02ae02a9f7c143a2b438cd93c91840f0192b9dd",
  "volta": {
    "node": "22.21.1"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "scripts": {
    "dev": "next dev --port 3009",
    "build": "next build",
    "start": "next start --port 3009",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:desktop": "playwright test --project=\"Desktop Chrome\"",
    "e2e:tablet": "playwright test --project=\"Tablet Safari\"",
    "e2e:mobile": "playwright test --project=\"Mobile Chrome\"",
    "prepare": "husky",
    "prettier": "prettier --ignore-unknown --write .",
    "clean": "rm -rf .next node_modules .playwright-mcp test-results playwright-report .pnpm-store",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@vercel/analytics": "^2.0.1",
    "better-auth": "^1.6.10",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.11",
    "next": "^16.2.6",
    "next-intl": "^4.11.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3.3.5",
    "@laststance/react-next-eslint-plugin": "^2.2.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.11.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
